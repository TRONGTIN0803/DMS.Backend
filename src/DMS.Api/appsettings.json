{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Database": {
    "MigrateOnStartup": false,
    "SeedOnStartup": false
  },
  "BackgroundJobs": {
    "Enabled": true
  },
  "Hangfire": {
    "Enabled": false
  },
  "RabbitMq": {
    "Enabled": false,
    "Host": "localhost",
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest"
  },
  "Jwt": {
    "Issuer": "DMS.Api",
    "Audience": "DMS.Api",
    "Secret": "dev-only-change-this-secret-before-production",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
